# ════════════════════════════════════════════════════════════
# RETAIL POST-PURCHASE GAMIFICATION — Environment Variables
# Copy this file to .env.local and fill in your values
# ════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────
# PostgreSQL — Neon (neon.tech) recommended for production
DATABASE_URL="postgresql://postgres:password@localhost:5432/retail_gamify"

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── Better Auth (Admin) ───────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secret-better-auth-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Customer Session (JWT) ────────────────────────────────
# Generate: openssl rand -base64 32
CUSTOMER_SESSION_SECRET="your-customer-session-secret-min-32-chars"

# ─── Email OTP (Resend) ────────────────────────────────────
# Sign up at resend.com — free tier: 3,000 emails/month
# OTP is delivered via email only (no SMS)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
# IMPORTANT: Domain must be verified in Resend dashboard

# ─── OTP Configuration ─────────────────────────────────────
OTP_EXPIRY_MINUTES="10"
OTP_MAX_ATTEMPTS="5"

# ─── QR Code ───────────────────────────────────────────────
# How long QR codes remain valid after generation (hours)
QR_EXPIRY_HOURS="24"

# ─── Production Only ───────────────────────────────────────
# Upstash Redis for rate limiting
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# Vercel Blob for image storage
# BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"

# Sentry error monitoring
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
# SENTRY_AUTH_TOKEN="your_sentry_auth_token"
