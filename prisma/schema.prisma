// ============================================================
// RETAIL POST-PURCHASE GAMIFICATION PLATFORM
// Prisma Schema v2.0
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum OTPPurpose {
  LOGIN
  REGISTER
  VERIFY_EMAIL
  VERIFY_PHONE
}

enum QRStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REVOKED
}

enum CreditTransactionType {
  EARNED_QR
  SPENT_GAME
  ADMIN_GRANT
  ADMIN_DEDUCT
  EXPIRED
  REFUND
}

enum GameType {
  TREASURE_BOX
  TREASURE_BOX_3D
  SCRATCH_CARD
  GACHAPON
  BLIND_BOX
}

enum GamePlayStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PrizeType {
  COUPON_CODE
  FREE_PRODUCT
  CUSTOM_PRIZE
  EMPTY
}

enum ProbabilityMode {
  PERCENTAGE // standard percentage chance
  CREDIT_COUNT // wins on every Nth game play
}

enum ClaimStatus {
  UNCLAIMED
  CLAIMED
  EXPIRED
  VOIDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  QR_GENERATE
  QR_REDEEM
  PRIZE_CLAIM
  PRIZE_UNCLAIM
  CREDIT_GRANT
  CREDIT_DEDUCT
}

// ============================================================
// RETAIL STORE
// ============================================================

model RetailStore {
  id        String    @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  staffs Staff[]

  @@index([deletedAt])
}

// ============================================================
// ADMIN (Better Auth managed)
// ============================================================

model Staff {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Better Auth relations
  sessions StaffSession[]
  accounts StaffAccount[]

  // App relations
  store         RetailStore     @relation(fields: [storeId], references: [id])
  storeId       String
  generatedQRs  QRCode[]        @relation("GeneratedBy")
  claimedPrizes CustomerPrize[] @relation("ClaimedBy")
  auditLogs     AuditLog[]

  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
}

model StaffSession {
  id        String   @id @default(cuid())
  staffId   String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([staffId])
}

model StaffAccount {
  id                    String    @id @default(cuid())
  staffId               String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([staffId])
}

model StaffVerification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ============================================================
// CUSTOMER
// ============================================================

model Customer {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String    @unique
  emailVerified Boolean   @default(false)
  totalCredits  Int       @default(0)
  totalSpent    Decimal   @default(0) @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  sessions          CustomerSession[]
  otpVerifications  OTPVerification[]
  qrRedemptions     QRCode[]            @relation("RedeemedBy")
  orders            Order[]
  creditTxns        CreditTransaction[]
  gamePlays         GamePlay[]
  prizes            CustomerPrize[]
  prizeReservations PrizeReservation[]

  @@index([email])
  @@index([phone])
  @@index([isActive])
  @@index([deletedAt])
}

model CustomerSession {
  id         String   @id @default(cuid())
  customerId String
  token      String   @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([customerId])
  @@index([expiresAt])
}

// ============================================================
// OTP VERIFICATION
// ============================================================

model OTPVerification {
  id          String     @id @default(cuid())
  customerId  String?
  identifier  String // email address
  channel     String     @default("EMAIL")
  purpose     OTPPurpose
  codeHash    String // bcrypt hashed OTP
  expiresAt   DateTime
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  lastSentAt  DateTime   @default(now())
  verifiedAt  DateTime?
  isUsed      Boolean    @default(false)
  ipAddress   String?
  createdAt   DateTime   @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([identifier])
  @@index([customerId])
  @@index([expiresAt])
  @@index([isUsed])
}

// ============================================================
// CAMPAIGN
// ============================================================

model Campaign {
  id             String    @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime?
  creditsPerUnit Int
  gameType       Int
  playCount      Int       @default(0)
  status         Int       @default(2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  qrCodes           QRCode[]
  gamePlays         GamePlay[]
  prizes            Prize[]
  prizeReservations PrizeReservation[]

  @@index([startDate, endDate])
  @@index([deletedAt])
}

model QRCode {
  id             String   @id @default(cuid())
  code           String   @unique @default(cuid())
  amountPaid     Decimal  @db.Decimal(10, 2)
  receiptNumber  String?
  creditsGranted Int
  status         QRStatus @default(ACTIVE)

  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  order Order?

  generatedBy   Staff  @relation("GeneratedBy", fields: [generatedById], references: [id])
  generatedById String

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String

  redeemedBy   Customer? @relation("RedeemedBy", fields: [redeemedById], references: [id])
  redeemedById String? // Customer ID

  @@index([code])
  @@index([status])
  @@index([campaignId])
  @@index([generatedById])
  @@index([redeemedById])
}

// ============================================================
// ORDER
// ============================================================

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  creditTransaction CreditTransaction?

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  qrCode   QRCode @relation(fields: [qrCodeId], references: [id])
  qrCodeId String @unique

  @@index([customerId])
  @@index([createdAt])
}

// ============================================================
// CREDIT TRANSACTIONS
// ============================================================

model CreditTransaction {
  id            String                @id @default(cuid())
  type          CreditTransactionType
  amount        Int // positive = earned, negative = spent
  balanceBefore Int
  balanceAfter  Int
  description   String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String? @unique

  gamePlay   GamePlay? @relation(fields: [gamePlayId], references: [id])
  gamePlayId String?   @unique

  @@index([customerId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// GAMES
// ============================================================

model GamePlay {
  id          String         @id @default(cuid())
  gameType    Int
  creditCost  Int
  status      GamePlayStatus @default(PENDING)
  result      Json? // game result data
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creditTransaction CreditTransaction?
  prizes            CustomerPrize[]

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?

  @@index([customerId])
  @@index([campaignId])
  @@index([gameType])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// PRIZES
// ============================================================

model Prize {
  id                      String          @id @default(cuid())
  name                    String
  type                    Int
  value                   String?
  winningProbabilityMode  ProbabilityMode @default(PERCENTAGE)
  winningProbabilityValue Float
  isActive                Boolean         @default(true)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  customerPrizes CustomerPrize[]

  campaign          Campaign           @relation(fields: [campaignId], references: [id])
  campaignId        String
  prizeReservations PrizeReservation[]

  @@index([campaignId])
  @@index([isActive])
}

model CustomerPrize {
  id            String      @id @default(cuid())
  claimStatus   ClaimStatus @default(UNCLAIMED)
  prizeSnapshot Json
  claimedAt     DateTime?
  wonAt         DateTime    @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  prize   Prize  @relation(fields: [prizeId], references: [id])
  prizeId String

  gamePlay   GamePlay? @relation(fields: [gamePlayId], references: [id])
  gamePlayId String?

  claimedBy   Staff?  @relation("ClaimedBy", fields: [claimedById], references: [id])
  claimedById String?

  @@index([customerId])
  @@index([prizeId])
  @@index([claimStatus])
  @@index([gamePlayId])
  @@index([claimedById])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  staff   Staff?  @relation(fields: [staffId], references: [id])
  staffId String?

  @@index([staffId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PrizeReservation {
  id        String   @id @default(cuid())
  expiresAt DateTime
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())

  prize   Prize  @relation(fields: [prizeId], references: [id])
  prizeId String

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String

  @@index([customerId])
  @@index([campaignId])
  @@index([prizeId])
}
